{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Pane",
  "version": "0.1.0",
  "identifier": "app.agentpane.desktop",
  "build": {
    "beforeDevCommand": "cd ../.. && npm run dev:web",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "cd ../.. && npm run build -w @agent-pane/shared && npm run build -w @agent-pane/web && npm run bundle:bridge -w @agent-pane/desktop",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Agent Pane",
        "width": 1280,
        "height": 840,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "trafficLightPosition": {
          "x": 24,
          "y": 28
        },
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bridge.cjs",
      "resources/browser-mcp.cjs"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {}
}
